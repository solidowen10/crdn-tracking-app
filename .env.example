NODE_ENV=production
PORT=3000
BASE_URL=https://tool.creativeden.studio
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=https://tool.creativeden.studio/auth/callback
SESSION_SECRET=replace-with-a-long-random-string
ALLOWED_LINE_IDS=U5519021173905415a32f76d7e1699e4d
DB_PATH=./data/crdn.db

# Google Sheets one-way export. The app remains the source of truth.
GOOGLE_SHEETS_SYNC_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=/var/www/crdn-tracking-app/secure/google-service-account.json

# Design AI Drive metadata sync. Share the Drive folders with this service account email.
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_PROJECT_ID=

# Design AI generation. If missing, the MVP saves a clearly marked placeholder direction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional LINE push notification for AI result-ready messages.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_DESIGN_NOTIFY_USER_IDS=
