<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CRDN Tracking</title>
  <style>
    :root{--bg:#f7f3ec;--ink:#1c1712;--muted:#766b5d;--line:#e3d9ca;--card:#fffaf2;--gold:#d4a96a;--dark:#1a1714;--green:#2f6b3f;--red:#9d2d25}
    *{box-sizing:border-box}body{margin:0;font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--bg);color:var(--ink)}
    header{background:var(--dark);color:#f6f1e8;padding:18px 22px;display:flex;justify-content:space-between;gap:16px;align-items:center;position:sticky;top:0;z-index:5}.brand{font-weight:800;font-size:18px}.user{font-size:13px;color:#d8cebe;display:flex;gap:12px;align-items:center}.logout{background:transparent;color:#f6f1e8;border:1px solid #5b5043;border-radius:10px;padding:8px 10px;cursor:pointer}
    .wrap{max-width:1280px;margin:0 auto;padding:22px;display:grid;grid-template-columns:330px 1fr;gap:18px}.panel{background:var(--card);border:1px solid var(--line);border-radius:20px;box-shadow:0 8px 30px rgba(50,36,16,.06);overflow:hidden}.panel h2{font-size:14px;text-transform:uppercase;letter-spacing:.09em;color:var(--muted);margin:0;padding:16px 18px;border-bottom:1px solid var(--line)}
    .side-body,.main-body{padding:16px}.vehicle{border:1px solid var(--line);background:white;border-radius:14px;padding:12px;margin-bottom:10px;cursor:pointer}.vehicle.active{border-color:var(--gold);box-shadow:0 0 0 2px rgba(212,169,106,.22)}.vehicle strong{display:block}.meta{font-size:12px;color:var(--muted);margin-top:4px}.row{display:grid;grid-template-columns:1fr 1fr;gap:10px}.field{margin-bottom:10px}label{font-size:12px;color:var(--muted);display:block;margin-bottom:4px}input,select,textarea{width:100%;border:1px solid var(--line);border-radius:10px;padding:10px;background:white;font:inherit}textarea{min-height:76px}.btn{border:0;border-radius:12px;padding:10px 12px;background:var(--dark);color:#fff;font-weight:700;cursor:pointer}.btn.secondary{background:#eee5d8;color:var(--ink)}.btn.danger{background:var(--red)}
    .topgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}.stat{background:white;border:1px solid var(--line);border-radius:16px;padding:14px}.stat .label{font-size:11px;text-transform:uppercase;color:var(--muted);letter-spacing:.08em}.stat .value{font-size:22px;font-weight:800;margin-top:4px}.category{background:white;border:1px solid var(--line);border-radius:16px;margin-bottom:12px;overflow:hidden}.cat-head{padding:12px 14px;background:#fbf6ee;border-bottom:1px solid var(--line);font-weight:800;display:flex;justify-content:space-between}.item{display:grid;grid-template-columns:32px 1fr 130px;gap:10px;align-items:center;padding:10px 14px;border-bottom:1px solid #f0e8dc}.item:last-child{border-bottom:0}.price{text-align:right}.save{font-size:12px;color:var(--muted);height:20px}.empty{text-align:center;padding:46px;color:var(--muted)}
    @media(max-width:900px){.wrap{grid-template-columns:1fr}.topgrid{grid-template-columns:1fr 1fr}.item{grid-template-columns:32px 1fr 110px}}
  </style>
</head>
<body>
  <header><div><div class="brand">CRDN Tracking</div><div class="meta">tool.creativeden.studio</div></div><div class="user"><span id="me">Loading...</span><form method="post" action="/auth/logout"><button class="logout">Logout</button></form></div></header>
  <div class="wrap">
    <aside class="panel"><h2>Vehicles / Projects</h2><div class="side-body"><div id="vehicles"></div><hr style="border:0;border-top:1px solid var(--line);margin:16px 0"><form id="vehicleForm"><div class="field"><label>Owner</label><input name="owner" required></div><div class="field"><label>Vehicle / Project Name</label><input name="name" required></div><div class="row"><div class="field"><label>Plate</label><input name="plate"></div><div class="field"><label>Package</label><input name="pkg"></div></div><button class="btn" style="width:100%">Add Vehicle</button></form></div></aside>
    <main class="panel"><h2>Tracking Dashboard</h2><div class="main-body" id="main"><div class="empty">Add or select a vehicle to begin.</div></div></main>
  </div>
<script>
const $ = (s, root=document) => root.querySelector(s);
const money = n => new Intl.NumberFormat('zh-TW',{style:'currency',currency:'TWD',maximumFractionDigits:0}).format(Number(n||0));
let vehicles=[], active=null, checklist=[], saveTimer=null, saveState='';
async function api(url, opts={}){ const r=await fetch(url,{headers:{'Content-Type':'application/json'},...opts}); if(!r.ok){throw new Error(await r.text())} return r.json(); }
async function boot(){ const me=await api('/auth/me'); $('#me').textContent=me.displayName; vehicles=await api('/api/vehicles'); renderVehicles(); if(vehicles[0]) selectVehicle(vehicles[0].id); }
function renderVehicles(){ $('#vehicles').innerHTML=vehicles.map(v=>`<div class="vehicle ${active&&active.id===v.id?'active':''}" onclick="selectVehicle(${v.id})"><strong>${escapeHtml(v.name)}</strong><div class="meta">${escapeHtml(v.owner)} · ${escapeHtml(v.stage||'New')}</div><div class="meta">${escapeHtml(v.plate||'No plate')} ${v.finish_date?'· Finish '+escapeHtml(v.finish_date):''}</div></div>`).join('') || '<div class="empty">No vehicles yet.</div>'; }
async function selectVehicle(id){ active=vehicles.find(v=>v.id===id); checklist=await api(`/api/vehicles/${id}/checklist`); renderVehicles(); renderMain(); }
function renderMain(){ if(!active) return; const selected = checklist.flatMap(c=>c.items).filter(i=>i.checked); const total = selected.reduce((sum,i)=>sum+Number(i.custom_price ?? i.default_price ?? 0),0); $('#main').innerHTML=`<div class="topgrid"><div class="stat"><div class="label">Stage</div><div class="value">${escapeHtml(active.stage||'New')}</div></div><div class="stat"><div class="label">Selected</div><div class="value">${selected.length}</div></div><div class="stat"><div class="label">Quote</div><div class="value">${money(total)}</div></div><div class="stat"><div class="label">Save</div><div class="value" style="font-size:15px" id="saveState">${saveState||'Ready'}</div></div></div><div class="panel" style="box-shadow:none;margin-bottom:14px"><h2>Vehicle Details</h2><div class="main-body"><div class="row"><div class="field"><label>Stage</label><select id="stage"><option>New</option><option>Consultation</option><option>Design</option><option>Approved</option><option>Production</option><option>Installation</option><option>QC</option><option>Delivered</option></select></div><div class="field"><label>Designer</label><input id="designer" value="${escapeAttr(active.designer||'')}"></div></div><div class="row"><div class="field"><label>Finish Date</label><input id="finish" type="date" value="${escapeAttr(active.finish_date||'')}"></div><div class="field"><label>Package</label><input id="pkg" value="${escapeAttr(active.pkg||'')}"></div></div><div class="field"><label>Notes</label><textarea id="notes">${escapeHtml(active.notes||'')}</textarea></div><button class="btn" onclick="saveVehicle()">Save Details</button> <button class="btn danger" onclick="archiveVehicle()">Archive</button></div></div><div>${checklist.map(renderCategory).join('')}</div>`; $('#stage').value=active.stage||'New'; }
function renderCategory(cat){ return `<section class="category"><div class="cat-head"><span>${escapeHtml(cat.name)}</span><span>${money(cat.items.filter(i=>i.checked).reduce((s,i)=>s+Number(i.custom_price ?? i.default_price ?? 0),0))}</span></div>${cat.items.map(i=>`<div class="item"><input type="checkbox" ${i.checked?'checked':''} onchange="changeItem(${i.id}, 'checked', this.checked)"><div>${escapeHtml(i.name)}<div class="meta">Default ${money(i.default_price)}</div></div><input class="price" type="number" min="0" value="${i.custom_price ?? i.default_price}" onchange="changeItem(${i.id}, 'price', this.value)"></div>`).join('')}</section>`; }
function findItem(id){ for(const c of checklist){ const item=c.items.find(i=>i.id===id); if(item) return item; } }
function changeItem(id, key, value){ const item=findItem(id); if(key==='checked') item.checked=value?1:0; if(key==='price') item.custom_price=Number(value); renderMain(); scheduleSave(); }
function scheduleSave(){ clearTimeout(saveTimer); saveState='Saving...'; $('#saveState').textContent=saveState; saveTimer=setTimeout(saveChecklist,800); }
async function saveChecklist(){ const updates=checklist.flatMap(c=>c.items).map(i=>({itemId:i.id,checked:!!i.checked,price:i.custom_price ?? i.default_price})); await api(`/api/vehicles/${active.id}/checklist`,{method:'PATCH',body:JSON.stringify(updates)}); saveState='Saved'; if($('#saveState')) $('#saveState').textContent=saveState; }
async function saveVehicle(){ const payload={stage:$('#stage').value,designer:$('#designer').value,finish_date:$('#finish').value,pkg:$('#pkg').value,notes:$('#notes').value}; active=await api(`/api/vehicles/${active.id}`,{method:'PATCH',body:JSON.stringify(payload)}); vehicles=await api('/api/vehicles'); renderVehicles(); renderMain(); }
async function archiveVehicle(){ if(!confirm('Archive this vehicle?')) return; await api(`/api/vehicles/${active.id}`,{method:'DELETE'}); active=null; vehicles=await api('/api/vehicles'); renderVehicles(); $('#main').innerHTML='<div class="empty">Select a vehicle to continue.</div>'; }
$('#vehicleForm').addEventListener('submit',async e=>{ e.preventDefault(); const body=Object.fromEntries(new FormData(e.target)); const v=await api('/api/vehicles',{method:'POST',body:JSON.stringify(body)}); e.target.reset(); vehicles=await api('/api/vehicles'); selectVehicle(v.id); });
function escapeHtml(s){return String(s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]))} function escapeAttr(s){return escapeHtml(s).replace(/'/g,'&#39;')}
boot().catch(err=>{console.error(err); document.body.innerHTML='<pre style="padding:24px">'+escapeHtml(err.message)+'</pre>'});
</script>
</body>
</html>
