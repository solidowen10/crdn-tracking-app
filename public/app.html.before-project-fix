function renderDash(filter='All'){
  const active=projects.filter(p=>!p.archived&&sIdx(p.stage)>=1&&sIdx(p.stage)<=12);
  const waitP=projects.filter(p=>!p.archived&&sIdx(p.stage)>=6&&sIdx(p.stage)<=7);
  const tot=active.reduce((s,p)=>s+calcTotal(p),0);
  const now=new Date(),weekOut=new Date(now.getTime()+7*24*60*60*1000);
  const dueWeek=active.filter(p=>p.finish&&new Date(p.finish)>=now&&new Date(p.finish)<=weekOut).length;
  document.getElementById('s-active').textContent=commas(active.length);
  document.getElementById('s-parts').textContent=commas(waitP.length);
  document.getElementById('s-due').textContent=commas(dueWeek);
  document.getElementById('s-total').textContent=tot>=1000?'NT$'+commas(Math.round(tot/1000))+'K':fmt(tot);

  let shown=projects;
  if(filter==='Active')shown=projects.filter(p=>!p.archived&&sIdx(p.stage)>=1&&sIdx(p.stage)<=12);
  else if(filter==='Waiting')shown=projects.filter(p=>!p.archived&&p.stage==='04 Waiting Approval');
  else if(filter==='Parts')shown=projects.filter(p=>!p.archived&&['07 Parts Ordering','08 Parts Arrived'].includes(p.stage));
  else if(filter==='Building')shown=projects.filter(p=>!p.archived&&['09 Building','10 Installation'].includes(p.stage));
  else if(filter==='Delivered')shown=projects.filter(p=>!p.archived&&p.stage==='13 Delivered');
  else if(filter==='Archived')shown=projects.filter(p=>p.archived||p.stage==='14 Archived');

  const list=document.getElementById('plist');list.innerHTML='';
  if(!shown.length){list.innerHTML='<div style="padding:40px;text-align:center;color:var(--g300)">No projects found</div>';return;}
  shown.forEach(p=>{
    const pct=sPct(p.stage),col=sCol(p.stage),t=calcTotal(p);
    const d=document.createElement('div');d.className='pcard';
    d.innerHTML=`
      <div class="pc-h">
