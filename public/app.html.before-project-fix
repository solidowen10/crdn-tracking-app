function openNewModal(){
  // Refresh package dropdown
  const sel=document.getElementById('m-pkg');
  if(sel)sel.innerHTML='<option value="">— No package —</option>'+PACKAGES.map(pk=>`<option value="${pk.id}">${pk.name}</option>`).join('');
  window._selectedPkgItems=[];
  document.getElementById('modal-new').classList.add('open');
}
function closeModal(id){document.getElementById(id).classList.remove('open');}
['modal-new','modal-addq','modal-adduser'].forEach(id=>{
  document.getElementById(id)?.addEventListener('click',e=>{if(e.target.id===id)closeModal(id);});
});
async function createProject(){
  const owner=document.getElementById('m-owner').value||'New Customer';
  const vehicle=document.getElementById('m-vehicle').value||'Vehicle';
  const plate=document.getElementById('m-plate').value;
  const pkgSel=document.getElementById('m-pkg');
  const pkgId=pkgSel?.value||'';
  const pkg=pkgId?PACKAGES.find(p=>p.id===pkgId)?.name||'':document.getElementById('m-pkg')?.options[document.getElementById('m-pkg').selectedIndex]?.text||'';
  const designer=document.getElementById('m-designer').value;
  const preItems=pkgId?PACKAGES.find(p=>p.id===pkgId)?.items||[]:[];

  const res=await POST('/api/projects',{owner,vehicle,plate,pkg,designer,stage:'02 Consultation',priority:'Normal'});
  const id=res?.id||Date.now();
  const num=res?.jobNo||`CRDN-${String(projects.length+1).padStart(3,'0')}`;
  const p={id,jobNo:num,owner,vehicle,plate,pkg,stage:'02 Consultation',priority:'Normal',designer,finish:'',
    checkedItems:[...preItems],itemQtys:{},customItems:[],partsStatus:{},stockStatus:{},notes:'',saved:false,archived:false,
    timeline:[{time:nowStr(),user:currentUser.displayName,action:'Project created',old:'',nv:num+' · '+vehicle+' · '+owner+(pkg?' · '+pkg:''),type:'create'}]};
  projects.unshift(p);
  closeModal('modal-new');
  ['m-owner','m-vehicle','m-plate'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  openDetail(p);
}

