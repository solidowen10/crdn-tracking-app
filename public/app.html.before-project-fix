<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>CRDN — Project Tracker</title>
<link rel="icon" type="image/png" href="https://www.creativeden.studio/wp-content/uploads/2023/09/CRDN-Square.png">
<link rel="apple-touch-icon" href="https://www.creativeden.studio/wp-content/uploads/2023/09/CRDN-Square.png">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --brand:#CA741F;--brand-d:#a55c15;--brand-l:#f9ede0;--brand-f:#fdf8f3;
  --black:#111110;--g700:#3d3d3b;--g500:#6b6b68;--g400:#8c8c89;
  --g300:#b8b8b4;--g200:#e2e2de;--g100:#f0f0ec;--g50:#f8f8f5;--w:#fff;
  --r:10px;--rs:6px;--sh:0 1px 4px rgba(0,0,0,.07);--shm:0 8px 24px rgba(0,0,0,.12);
  --danger:#dc2626;--dl:#fef2f2;
  --fs:16px;--sm:15px;--xs:14px;--xxs:13px;--xxxs:12px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Noto Sans TC',sans-serif;background:var(--g50);color:var(--black);font-size:var(--fs);height:100dvh;display:flex;flex-direction:column;overflow:hidden}
input,select,textarea,button{font-family:'Noto Sans TC',sans-serif;font-size:var(--fs)}
button{cursor:pointer}
.bb{font-family:'Bebas Neue',sans-serif;letter-spacing:.05em}

/* TOPBAR */
.topbar{height:56px;background:var(--w);border-bottom:1px solid var(--g200);display:flex;align-items:center;padding:0 18px;gap:12px;flex-shrink:0;z-index:50;box-shadow:var(--sh)}
.tlogo{display:flex;align-items:center;gap:10px;cursor:pointer;text-decoration:none}
.tlogo img{width:34px;height:34px;border-radius:7px;object-fit:cover}
.tlogo-name{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.06em;white-space:nowrap}
.tlogo-name span{color:var(--brand)}
.tright{margin-left:auto;display:flex;gap:8px;align-items:center}
.upill{display:flex;align-items:center;gap:6px;padding:5px 12px;background:var(--g100);border-radius:99px;font-size:var(--xxs);font-weight:500;cursor:pointer}
.udot{width:7px;height:7px;border-radius:50%;background:#22c55e}
.menu-wrap{position:relative;display:flex;align-items:center}
.menu-btn{width:34px;height:34px;border:1px solid var(--g200);border-radius:var(--rs);background:var(--w);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:0;transition:.15s}
.menu-btn:hover{background:var(--g50);border-color:var(--g300)}
.menu-btn span{width:16px;height:2px;border-radius:2px;background:var(--black);display:block}
.nav-menu{position:absolute;right:0;top:42px;min-width:156px;background:var(--w);border:1px solid var(--g200);border-radius:var(--r);box-shadow:var(--shm);padding:6px;display:none;z-index:120}
.nav-menu.open{display:flex;flex-direction:column;gap:3px}
.nav-menu button{border:none;background:transparent;color:var(--black);font-size:var(--sm);font-weight:600;text-align:left;padding:9px 10px;border-radius:var(--rs);cursor:pointer}
.nav-menu button:hover{background:var(--brand-f);color:var(--brand)}

/* BUTTONS */
.btn{padding:8px 15px;border-radius:var(--rs);font-size:var(--xs);font-weight:500;border:none;transition:.15s;line-height:1;cursor:pointer;display:inline-flex;align-items:center;gap:5px;white-space:nowrap}
.btn-brand{background:var(--brand);color:#fff}.btn-brand:hover{background:var(--brand-d)}
.btn-dark{background:var(--black);color:#fff}.btn-dark:hover{background:var(--g700)}
.btn-out{background:var(--w);color:var(--g700);border:1px solid var(--g200)}.btn-out:hover{background:var(--g50);border-color:var(--g300)}
.btn-ghost{background:none;color:var(--g500);border:none;padding:6px 8px}.btn-ghost:hover{color:var(--black)}
.btn-danger{background:var(--dl);color:var(--danger);border:1px solid #fecaca}.btn-danger:hover{background:#fee2e2}
.btn-green{background:#15803d;color:#fff}.btn-green:hover{background:#166534}
.btn-amber{background:#fffbeb;color:#92400e;border:1px solid #fde68a}.btn-amber:hover{background:#fef3c7}
.btn-sm{padding:6px 11px;font-size:var(--xxs)}
.btn-xs{padding:4px 8px;font-size:var(--xxxs)}
.btn:disabled{opacity:.4;cursor:not-allowed}

/* LAYOUT */
.layout{flex:1;overflow:hidden;display:flex;position:relative}
.view{position:absolute;inset:0;overflow-y:auto;display:none;flex-direction:column}
.view.active{display:flex}

/* DASHBOARD */
.dash-bar{padding:12px 18px;background:var(--w);border-bottom:1px solid var(--g200);flex-shrink:0;display:flex;flex-direction:column;gap:10px}
.dash-h{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:.06em}
.frow{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none}
.frow::-webkit-scrollbar{display:none}
.fchip{padding:6px 14px;border-radius:99px;font-size:var(--xxs);font-weight:500;white-space:nowrap;border:1px solid var(--g200);background:var(--w);color:var(--g500);cursor:pointer;transition:.15s;flex-shrink:0}
.fchip.on{background:var(--brand);color:#fff;border-color:var(--brand)}
.sgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px;padding:14px 18px}
.sc{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);padding:14px}
.sc.hi{border-left:3px solid var(--brand)}
.sl{font-size:var(--xxxs);font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--g400);margin-bottom:5px}
.sn{font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:.04em;line-height:1}
.ss-sub{font-size:var(--xxxs);color:var(--g400);margin-top:3px}
.plist{padding:0 18px 100px}
.pcard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);margin-bottom:10px;cursor:pointer;transition:.15s;overflow:hidden}
.pcard:hover{border-color:var(--g300);box-shadow:var(--sh)}
.pc-h{padding:13px 15px 8px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.pc-t{font-size:16px;font-weight:700}
.pc-s{font-size:var(--xxs);color:var(--g500);margin-top:2px}
.pc-b{padding:0 15px 11px;display:grid;grid-template-columns:minmax(145px,1.25fr) minmax(130px,1fr) minmax(86px,.7fr) minmax(78px,.55fr);gap:8px 12px;align-items:center}
.spill{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:99px;font-size:var(--xxs);font-weight:600;white-space:nowrap}
.sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.pri{font-size:11px;font-weight:700;padding:2px 9px;border-radius:99px}
.pri-High{background:#fef2f2;color:#ef4444}.pri-Normal{background:var(--g100);color:var(--g500)}.pri-Low{background:#f0fdf4;color:#16a34a}
.prog{display:flex;align-items:center;gap:6px}
.pbar{height:4px;background:var(--g200);border-radius:2px;overflow:hidden;min-width:64px;flex:1}
.pfill{height:100%;background:var(--brand);border-radius:2px;transition:.4s}
.ppct{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:.04em;color:var(--g500)}
.designer-pill{font-size:var(--xxs);color:var(--g500);white-space:nowrap}
.job-pill{font-family:'Bebas Neue',sans-serif;font-size:15px;color:var(--brand);letter-spacing:.04em;white-space:nowrap;text-align:right}
.pc-status{font-size:var(--xxxs);padding:2px 8px;border-radius:99px;width:max-content}
.pc-status.unsaved{background:#fff7ed;color:#f97316}
.pc-status.archived{background:#fef3c7;color:#92400e}
.pc-f{padding:9px 15px;background:var(--g50);border-top:1px solid var(--g100);font-size:var(--xxs);color:var(--g500);display:flex;justify-content:space-between;align-items:center}
.qamt{font-family:'Bebas Neue',sans-serif;font-size:17px;color:var(--brand);letter-spacing:.04em}

/* DETAIL */
.det-h{background:var(--w);border-bottom:1px solid var(--g200);flex-shrink:0;position:sticky;top:0;z-index:40}
.crumb{padding:9px 18px 0;font-size:var(--xxs);color:var(--g400);display:flex;gap:4px;align-items:center}
.ca{cursor:pointer}.ca:hover{color:var(--brand)}
.det-tr{padding:4px 18px 0;display:flex;align-items:flex-start;gap:8px}
.det-t{font-size:20px;font-weight:700;flex:1}
.det-sub{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:.05em;color:var(--g400);padding:3px 18px 7px}
.tbar{display:flex;overflow-x:auto;scrollbar-width:none;border-top:1px solid var(--g100)}
.tbar::-webkit-scrollbar{display:none}
.dtab{padding:10px 16px;font-size:var(--xs);font-weight:500;color:var(--g400);border:none;background:none;border-bottom:2px solid transparent;white-space:nowrap;flex-shrink:0;transition:.15s;font-family:'Noto Sans TC',sans-serif}
.dtab.on{color:var(--brand);border-bottom-color:var(--brand)}
.tb{padding:16px;padding-bottom:120px;flex:1}

/* FIELD CARD */
.fc{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);padding:16px;margin-bottom:13px}
.fct{font-size:var(--xxs);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--g400);margin-bottom:13px}
.fr{display:flex;align-items:flex-start;gap:9px;margin-bottom:11px}
.fr:last-child{margin-bottom:0}
.fl{font-size:var(--xxs);color:var(--g500);width:96px;flex-shrink:0;padding-top:9px}
.fi{border:1px solid var(--g200);border-radius:var(--rs);padding:8px 11px;font-size:var(--sm);flex:1;color:var(--black);background:var(--w);font-family:'Noto Sans TC',sans-serif;width:100%;transition:.15s}
.fi:focus{outline:none;border-color:var(--brand);box-shadow:0 0 0 3px rgba(202,116,31,.1)}
.fsel{border:1px solid var(--g200);border-radius:var(--rs);padding:8px 11px;font-size:var(--sm);background:var(--w);color:var(--black);font-family:'Noto Sans TC',sans-serif;width:100%}
.fsel:focus{outline:none;border-color:var(--brand)}
.sbar{display:flex;gap:3px;margin:9px 0}
.sbs{flex:1;height:6px;border-radius:3px;background:var(--g200);transition:.4s}
.depbanner{background:#fff7ed;border:1px solid #fed7aa;border-radius:var(--r);padding:13px 15px;margin-bottom:13px;display:flex;gap:10px;align-items:flex-start}
.db-ico{font-size:20px;flex-shrink:0}
.db-t{font-size:var(--xs);color:#9a3412;line-height:1.6}
.db-t strong{display:block;color:#7c2d12;font-size:var(--sm);margin-bottom:2px}

/* CONSULTATION */
.cwrap{display:flex;gap:16px}
.cleft{flex:1;min-width:0}
.cright{width:300px;flex-shrink:0;position:sticky;top:0;align-self:flex-start}
@media(max-width:700px){
  .topbar{height:64px;padding:0 14px;gap:10px}
  .tlogo{gap:12px;min-width:0}
  .tlogo img{width:38px;height:38px}
  .tlogo-name{font-size:18px;letter-spacing:.055em;line-height:1;white-space:normal;max-width:152px}
  .tright{gap:9px}
  .upill{display:none}
  .menu-btn{width:38px;height:38px}
  .nav-menu{top:46px}
  .cwrap{flex-direction:column}
  .cright{width:100%;position:static}
  .hide-sm{display:none}
  .pc-b{grid-template-columns:1fr 1fr}
  .job-pill{text-align:left}
}
.cat-sec{margin-bottom:16px}
.cat-h{font-size:var(--xxs);font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--g400);padding:7px 0;border-bottom:1px solid var(--g100);margin-bottom:9px;display:flex;align-items:center;justify-content:space-between}
.chk{display:flex;align-items:center;gap:11px;padding:12px 14px;border-radius:var(--rs);border:1px solid var(--g200);background:var(--w);margin-bottom:7px;cursor:pointer;transition:.15s;-webkit-user-select:none;user-select:none}
.chk:hover{border-color:var(--g300)}
.chk.on{border-color:var(--brand);background:var(--brand-f)}
.cbox{width:24px;height:24px;border-radius:6px;border:2px solid var(--g300);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:.15s}
.chk.on .cbox{background:var(--brand);border-color:var(--brand)}
.ctick{display:none;color:#fff;font-size:15px;font-weight:700;line-height:1}
.chk.on .ctick{display:block}
.ci{flex:1;min-width:0}
.cn{font-size:var(--sm);font-weight:600}
.cd{font-size:var(--xxs);color:var(--g400);margin-top:2px}
.cp{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:.04em;white-space:nowrap;flex-shrink:0}
.chk.on .cp{color:var(--brand)}
.chk:not(.on) .cp{color:var(--g300)}
.qtyc{display:flex;align-items:center;flex-shrink:0}
.qb{width:28px;height:28px;border:1px solid var(--g200);background:var(--w);font-size:17px;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.15s;user-select:none;flex-shrink:0}
.qb:first-child{border-radius:var(--rs) 0 0 var(--rs)}.qb:last-child{border-radius:0 var(--rs) var(--rs) 0}
.qb:hover:not(.qbh){background:var(--g100)}.qbh{display:none;pointer-events:none}
.qv{min-width:32px;height:28px;border-top:1px solid var(--g200);border-bottom:1px solid var(--g200);display:flex;align-items:center;justify-content:center;font-size:var(--xs);font-weight:700;background:var(--w);padding:0 4px}
.qbh + .qv,.qbh + .qvs{border-left:1px solid var(--g200);border-radius:var(--rs) 0 0 var(--rs)}
.crow{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(--rs);border:1px solid var(--brand);background:var(--brand-f);margin-bottom:7px}
.crn{flex:1;border:1px solid var(--g200);border-radius:var(--rs);padding:7px 10px;font-size:var(--sm);background:var(--w);color:var(--black)}
.crp{width:115px;border:1px solid var(--g200);border-radius:var(--rs);padding:7px 10px;font-size:var(--sm);text-align:right;font-family:'Bebas Neue',sans-serif;letter-spacing:.04em;background:var(--w);color:var(--black)}
.crn:focus,.crp:focus{outline:none;border-color:var(--brand)}
.crdel{background:none;border:none;color:var(--g300);cursor:pointer;font-size:20px;line-height:1;padding:2px 5px;border-radius:3px;flex-shrink:0}
.crdel:hover{color:var(--danger)}

/* QUOTE PANEL */
.qpanel{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);overflow:hidden}
.qph{background:var(--black);color:#fff;padding:12px 15px;display:flex;align-items:center;justify-content:space-between}
.qpt{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:.06em}
.qpn{font-size:var(--xxs);color:var(--g400)}
.qpb{max-height:340px;overflow-y:auto}
.qpe{padding:28px;text-align:center;color:var(--g300);font-size:var(--sm);font-style:italic}
.qpl{display:flex;justify-content:space-between;align-items:flex-start;padding:9px 15px;border-bottom:1px solid var(--g100);gap:8px}
.qpl:last-child{border-bottom:none}
.qpln{font-size:var(--xxs);font-weight:600;flex:1}
.qplc{font-size:11px;color:var(--g400)}
.qpla{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:.04em;white-space:nowrap}
.qptotal{padding:13px 15px;border-top:2px solid var(--g200);display:flex;justify-content:space-between;align-items:center;background:var(--g50)}
.qptl{font-size:var(--sm);font-weight:600;color:var(--g500)}
.qpta{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:.04em;color:var(--brand)}
.qpact{padding:11px 15px;display:flex;gap:8px;border-top:1px solid var(--g100)}
.mobbar{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--black);padding:11px 18px;z-index:45;align-items:center;justify-content:space-between}
@media(max-width:700px){.mobbar.show{display:flex}}
.mba{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:.04em;color:var(--brand)}
.mbl{font-size:11px;color:var(--g400)}

/* QUOTE TAB */
.qtwrap{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);overflow:hidden;margin-bottom:13px}
.qt{width:100%;border-collapse:collapse}
.qt th{padding:9px 11px;text-align:left;font-size:var(--xxxs);font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--g400);background:var(--g50);border-bottom:1px solid var(--g100);white-space:nowrap}
.qt th.c,.qt td.c{text-align:center}
.qt th.r,.qt td.r{text-align:right}
.qt td{padding:10px 11px;border-bottom:1px solid var(--g100);vertical-align:middle;font-size:var(--sm)}
.qt tr:last-child td{border-bottom:none}
.qt tr:hover td{background:var(--brand-f)}
.qtfoot{background:var(--g50);border-top:2px solid var(--g200)}
.qtfoot td{padding:12px 11px;font-weight:700;font-size:var(--fs)}
.delbtn{background:none;border:none;color:var(--g300);cursor:pointer;font-size:20px;line-height:1;padding:2px 7px;border-radius:3px;transition:.15s}
.delbtn:hover{color:var(--danger);background:var(--dl)}
.qterms{background:var(--g50);border-radius:var(--rs);padding:12px 14px;font-size:var(--sm);color:var(--g500);line-height:1.7;white-space:pre-wrap}
.qtyc-sm{display:flex;align-items:center;justify-content:center}
.qbs{width:26px;height:26px;border:1px solid var(--g200);background:var(--w);font-size:16px;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.15s;flex-shrink:0}
.qbs:first-child{border-radius:var(--rs) 0 0 var(--rs)}.qbs:last-child{border-radius:0 var(--rs) var(--rs) 0}
.qbs:hover:not(.qbh){background:var(--g100)}
.qvs{min-width:30px;height:26px;border-top:1px solid var(--g200);border-bottom:1px solid var(--g200);display:flex;align-items:center;justify-content:center;font-size:var(--xxs);font-weight:700;background:var(--w);padding:0 4px}

/* PARTS */
.psgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:15px}
.psc{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);padding:12px;text-align:center}
.psn{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:.04em}
.psl{font-size:11px;color:var(--g400);margin-top:3px}
.ptcard{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);padding:14px 16px;margin-bottom:9px}
.ptn{font-size:var(--sm);font-weight:700}
.ptm{font-size:var(--xxs);color:var(--g500);margin-top:2px}
.pst{display:inline-block;padding:2px 10px;border-radius:99px;font-size:var(--xxs);font-weight:600}
.pst-need{background:#fff7ed;color:#f97316}.pst-ordered{background:#eff6ff;color:#3b82f6}
.pst-arrived{background:#f0fdf4;color:#16a34a}.pst-installed{background:var(--brand-l);color:var(--brand-d)}
.pst-back{background:#fef2f2;color:#dc2626}.pst-none{background:var(--g100);color:var(--g400)}
.sptable{width:100%;font-size:var(--xs)}
.sptable td{padding:5px 0;border-bottom:1px solid var(--g100)}
.sptable tr:last-child td{border-bottom:none}
.stock-check{display:flex;align-items:center;gap:8px;cursor:pointer;color:var(--black)}
.stock-check input{width:16px;height:16px;accent-color:var(--brand);flex-shrink:0}
.stocked-row td{color:var(--g400)}
.stocked-row .stock-check span{text-decoration:line-through}
.stock-note{font-size:var(--xxxs);color:var(--g400);margin-bottom:7px}

/* TIMELINE */
.tli{display:flex;gap:11px;padding:11px 0;border-bottom:1px solid var(--g100)}
.tli:last-child{border-bottom:none}
.tlcol{display:flex;flex-direction:column;align-items:center;width:22px;flex-shrink:0}
.tldot{width:11px;height:11px;border-radius:50%;background:var(--brand);flex-shrink:0}
.tldot.m{background:var(--g300)}
.tlline{flex:1;width:1px;background:var(--g200);margin:3px 0}
.tlact{font-size:var(--sm);font-weight:600}
.tlmeta{font-size:var(--xxs);color:var(--g400);margin-top:3px}
.tlch{font-size:var(--xxs);margin-top:5px;background:var(--g50);border-radius:4px;padding:5px 10px;color:var(--g500)}
.tlold{text-decoration:line-through;color:var(--g300);margin-right:6px}
.tlnew{color:var(--black);font-weight:600}

/* ADMIN PROFIT */
.psum{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);padding:16px;display:grid;grid-template-columns:repeat(2,1fr);gap:13px;margin-bottom:13px}
.pslbl{font-size:var(--xxxs);font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--g400);margin-bottom:4px}
.psval{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:.04em}

/* SETTINGS */
.ss{background:var(--w);border:1px solid var(--g200);border-radius:var(--r);padding:16px;margin-bottom:13px}
.sst{font-size:var(--xxs);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--g400);margin-bottom:13px}
.cprow{padding:13px 0;border-bottom:1px solid var(--g100)}
.cprow:last-child{border-bottom:none}
.cphd{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:9px}
.cpname{font-size:var(--sm);font-weight:700}
.cpdesc{font-size:var(--xxs);color:var(--g500);margin-top:2px}
.pgrid{display:grid;grid-template-columns:repeat(3,minmax(120px,1fr));gap:12px;margin-bottom:9px;align-items:end}
.pbox{display:flex;flex-direction:column;gap:3px;min-width:0}
.plbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--g400)}
.pval{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:.04em;color:var(--brand)}
.pinp{border:1px solid var(--g200);border-radius:var(--rs);padding:7px 10px;width:100%;text-align:right;font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:.04em;color:var(--black)}
.pinp:focus{outline:none;border-color:var(--brand)}
.cost-display{border:1px solid var(--g200);border-radius:var(--rs);padding:7px 10px;min-height:37px;background:var(--g50);display:flex;align-items:center;justify-content:flex-end;font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:.04em;color:var(--black)}
@media(max-width:620px){.pgrid{grid-template-columns:repeat(2,minmax(0,1fr))}}
.sptog{font-size:var(--xxs);color:var(--brand);cursor:pointer;text-decoration:underline}
.spwrap{background:var(--g50);border-radius:var(--rs);padding:11px 13px;margin-top:9px;display:none}
.sprow{display:flex;align-items:center;gap:7px;margin-bottom:7px}
.spni{flex:1;border:1px solid var(--g200);border-radius:var(--rs);padding:6px 9px;font-size:var(--xxs);font-family:'Noto Sans TC',sans-serif}
.spni:focus,.spci:focus{outline:none;border-color:var(--brand)}
.spci{width:105px;border:1px solid var(--g200);border-radius:var(--rs);padding:6px 9px;font-size:var(--xxs);text-align:right;font-family:'Bebas Neue',sans-serif;letter-spacing:.04em}
.spdel{background:none;border:none;color:var(--g300);cursor:pointer;font-size:19px;padding:0 4px}
.spdel:hover{color:var(--danger)}
.sptot{display:flex;justify-content:space-between;align-items:center;padding:7px 0;margin-top:5px;border-top:2px solid var(--g200)}
.sptl{font-size:var(--xxs);font-weight:700;color:var(--g500)}
.sptv{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:.04em;color:var(--brand)}
/* Sheets */
.shrow{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--g100);font-size:var(--sm)}
.shrow:last-child{border-bottom:none}
.shlbl{color:var(--g500);font-size:var(--xxs)}
.shval{font-weight:500}
.st-ok{color:#15803d}.st-err{color:#dc2626}.st-off{color:var(--g400)}
.synctabs{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px}
.stchip{font-size:11px;padding:2px 9px;border-radius:99px;background:var(--brand-l);color:var(--brand-d);font-weight:500}
/* Package setting rows */
.pkgrow{display:flex;align-items:center;gap:8px;padding:10px 0;border-bottom:1px solid var(--g100)}
.pkgrow:last-child{border-bottom:none}
.pkgname{flex:1;font-size:var(--sm);font-weight:600}
/* inline edit row */
.iedit{border:none;background:transparent;font-size:var(--sm);font-weight:600;color:var(--black);font-family:'Noto Sans TC',sans-serif;width:100%;padding:2px 4px;border-radius:3px}
.iedit:hover{background:var(--g50)}
.iedit:focus{outline:none;background:var(--w);border:1px solid var(--brand);padding:2px 4px}
/* cat header row in settings */
.catrow{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--g100);background:var(--g50);margin:0 -16px;padding-left:16px;padding-right:16px}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.48);z-index:200;display:none;align-items:flex-end;justify-content:center}
.overlay.open{display:flex}
@media(min-width:520px){.overlay{align-items:center}}
.modal{background:var(--w);border-radius:16px 16px 0 0;width:100%;max-width:500px;max-height:92dvh;overflow-y:auto;padding:22px 18px;box-shadow:var(--shm)}
@media(min-width:520px){.modal{border-radius:var(--r)}}
.modalt{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:.06em;margin-bottom:18px}
.mf{margin-bottom:13px}
.mf label{display:block;font-size:var(--xxs);font-weight:600;color:var(--g500);margin-bottom:5px}
.mi{width:100%;border:1px solid var(--g200);border-radius:var(--rs);padding:10px 13px;font-size:var(--fs);font-family:'Noto Sans TC',sans-serif;color:var(--black)}
.mi:focus{outline:none;border-color:var(--brand)}
.msel{width:100%;border:1px solid var(--g200);border-radius:var(--rs);padding:10px 13px;font-size:var(--fs);background:var(--w);color:var(--black);font-family:'Noto Sans TC',sans-serif}
.mgrid{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.mbtns{display:flex;gap:8px;margin-top:18px}
.mbtns .btn{flex:1;padding:12px;font-size:var(--fs);justify-content:center}
/* spin */
.spin{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:sp .6s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
/* toast */
.toast-el{position:fixed;bottom:82px;left:50%;transform:translateX(-50%);background:var(--black);color:#fff;padding:11px 22px;border-radius:99px;font-size:var(--xs);font-weight:500;z-index:999;box-shadow:var(--shm);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .2s}
.toast-el.show{opacity:1}
@media print{
  .topbar,.bnav-wrap,.mobbar,.qpact,.no-print,.det-h{display:none!important}
  body{overflow:auto;height:auto;background:#fff}
  .view,.layout{position:static;overflow:visible;height:auto}
  .view.active{display:block}
  @page{margin:14mm}
}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--g200);border-radius:2px}
</style>
</head>
