}
async function deleteUser(i){
  const u=USERS[i];
  if(!confirm(`Remove ${u.name} from the team?`))return;
  await DELETE(`/api/admin/users/${u.id}`);
  USERS.splice(i,1);renderUsers();toast(`${u.name} removed`);
}
function openAddUser(){document.getElementById('modal-adduser').classList.add('open');}
async function addUser(){
  const name=document.getElementById('au-name').value.trim();
  const lineId=document.getElementById('au-id').value.trim();
  const role=document.getElementById('au-role').value;
  if(!name||!lineId){toast('Name and LINE ID required');return;}
  const res=await POST('/api/admin/users',{name,lineId,role});
  const newUser={id:res?.id||uid(),name,lineId,role};
  USERS.push(newUser);
  closeModal('modal-adduser');
  ['au-name','au-id'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  renderUsers();toast('Team member added ✓');
}

