// GOOGLE SHEETS SYNC
// ══════════════════════════════════════
async function loadSheetsStatus(){
  const el=document.getElementById('sheets-body');if(!el)return;
  const data=await GET('/api/admin/google-sheets/status');
  if(!data){el.innerHTML=sheetsHTML({enabled:false,spreadsheet_id:'',credentials_configured:false,tabs:[],last_synced_at:'',last_error:'API not reachable (check deployment)'});return;}
  el.innerHTML=sheetsHTML(data);
}
function sheetsHTML(d){
  const tabs=d.tabs||[];
  const lastSync=d.last_synced_at?new Date(d.last_synced_at).toLocaleString('zh-TW'):'Never';
  return`
    <div class="shrow"><span class="shlbl">Sync enabled</span><span class="shval ${d.enabled?'st-ok':'st-off'}">${d.enabled?'✅ Enabled':'⏸ Disabled'}</span></div>
    <div class="shrow"><span class="shlbl">Sheet ID</span><span class="shval" style="font-family:monospace;font-size:var(--xxs)">${d.spreadsheet_id||'— not set —'}</span></div>
    <div class="shrow"><span class="shlbl">Credentials</span><span class="shval ${d.credentials_configured?'st-ok':'st-err'}">${d.credentials_configured?'✅ Configured':'❌ Not configured'}</span></div>
    <div class="shrow"><span class="shlbl">Last synced</span><span class="shval">${lastSync}</span></div>
    ${d.last_error?`<div class="shrow"><span class="shlbl">Last error</span><span class="shval st-err" style="font-size:var(--xxs)">${d.last_error}</span></div>`:''}
    ${tabs.length?`<div style="margin-top:9px"><div class="shlbl" style="margin-bottom:6px">Exported tabs</div><div class="synctabs">${tabs.map(t=>`<span class="stchip">${t}</span>`).join('')}</div></div>`:''}`;
}
async function testSheets(){
  const btn=document.getElementById('btn-test');btn.disabled=true;btn.innerHTML='<div class="spin"></div> Testing…';
  const data=await GET('/api/admin/google-sheets/status?test=1');
  btn.disabled=false;btn.textContent='🔌 Test Connection';
  if(!data){toast('Cannot reach server',3000);return;}
  if(data.error){toast('❌ '+data.error,4000);return;}
  if(data.test?.ok){
    const el=document.getElementById('sheets-body');if(el)el.innerHTML=sheetsHTML(data);
    toast(`✅ Connected — "${data.test.title}"`);
  } else {toast('❌ Connection failed',3500);}
}
async function syncNow(){
  const btn=document.getElementById('btn-sync');btn.disabled=true;btn.innerHTML='<div class="spin"></div> Syncing…';
  const data=await POST('/api/admin/google-sheets/sync',{});
  btn.disabled=false;btn.textContent='⬆ Sync Now';
  if(!data){toast('Sync failed — check server logs',3500);return;}
  if(data.error){toast('❌ '+data.error,4000);return;}
  if(data.ok){
    const el=document.getElementById('sheets-body');if(el&&data.status)el.innerHTML=sheetsHTML(data.status);
    const counts=data.counts?Object.entries(data.counts).map(([k,v])=>`${k}:${commas(v)}`).join(', '):'';
    toast(`✅ Synced${counts?' — '+counts:''}`,3500);
  }
}

