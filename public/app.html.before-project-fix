function updPS(itemId,val){
  const p=AP;if(!p.partsStatus)p.partsStatus={};
  const old=p.partsStatus[itemId]||'Need to Order';
  p.partsStatus[itemId]=val;
  p.timeline.unshift({time:nowStr(),user:currentUser.displayName,action:'Part status changed',old,nv:`${itemById(itemId)?.name} → ${val}`,type:'parts'});
  PATCH(`/api/projects/${p.id}/parts/${itemId}`,{status:val});
  toast('Part status updated ✓');
}
function toggleSubpartStock(itemId,index,checked){
  const p=AP;if(!p)return;
  if(!p.stockStatus)p.stockStatus={};
  p.stockStatus[subpartStockKey(itemId,index)]=checked?1:0;
  p.timeline.unshift({time:nowStr(),user:currentUser.displayName,action:'Sub-part stock changed',old:'',nv:`${itemById(itemId)?.name} sub-part ${index+1} → ${checked?'In stock':'Need to order'}`,type:'parts'});
  rParts(document.getElementById('tb'));
  toast(checked?'Marked in stock':'Marked need to order');
}

