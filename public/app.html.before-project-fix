function rAdmin(body){
  const p=AP;
  const checked=p.checkedItems.map(id=>({item:itemById(id),cust:effP(id),cost:spTot(id),q:qty(p,id)})).filter(x=>x.item);
  const customs=(p.customItems||[]).map(e=>({item:{name:e.name||'Custom item'},cust:e.price||0,cost:e.cost||0,q:e.qty||1}));
  const all=[...checked,...customs];
  const totC=all.reduce((s,x)=>s+x.cust*x.q,0);
  const totCo=all.reduce((s,x)=>s+x.cost*x.q,0);
  const profit=totC-totCo,margin=totC?Math.round(profit/totC*100):0;
  const rows=all.map(x=>{
    const xP=(x.cust-x.cost)*x.q,xM=x.cust?Math.round((x.cust-x.cost)/x.cust*100):0;
