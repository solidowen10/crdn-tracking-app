        <span class="designer-pill">👤 ${p.designer||'—'}</span>
        <span class="job-pill">${p.jobNo}</span>
        ${!p.saved?'<span class="pc-status unsaved">Unsaved</span>':''}
        ${p.archived?'<span class="pc-status archived">Archived</span>':''}
      </div>
      <div class="pc-f">
        <span class="qamt">${t?fmt(t):'No quote'}</span>
        <span>${p.finish?'📅 '+p.finish:'TBD'}</span>
