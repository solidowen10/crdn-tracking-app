      <td class="r bb" style="font-size:15px;color:var(--g500)">${fmt(x.cost*x.q)}</td>
      <td class="c bb" style="font-size:15px;color:${xP>=0?'#15803d':'#dc2626'}">${fmt(xP)}</td>
      <td class="c bb" style="font-size:15px;color:var(--brand)">${xM}%</td>
    </tr>`;}).join('');
  body.innerHTML=`
    <div class="qtwrap" style="margin-bottom:15px">
      <table class="qt">
        <thead><tr><th>Item</th><th class="c">Qty</th><th class="r">Revenue</th><th class="r">Cost</th><th class="c">Profit</th><th class="c">Margin</th></tr></thead>
