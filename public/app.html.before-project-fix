        <tfoot class="qtfoot"><tr>
          <td style="color:var(--g500);font-size:var(--xxs)">Totals</td><td></td>
          <td class="r bb" style="font-size:18px">${fmt(totC)}</td>
          <td class="r bb" style="font-size:18px;color:var(--g500)">${fmt(totCo)}</td>
          <td class="c bb" style="font-size:18px;color:#15803d">${fmt(profit)}</td>
          <td class="c bb" style="font-size:18px;color:var(--brand)">${margin}%</td>
        </tr></tfoot>
      </table>
    </div>
    <div class="psum">
      <div><div class="pslbl">Revenue</div><div class="psval">${fmt(totC)}</div></div>
      <div><div class="pslbl">Cost</div><div class="psval" style="color:var(--g500)">${fmt(totCo)}</div></div>
      <div><div class="pslbl">Profit</div><div class="psval" style="color:#15803d">${fmt(profit)}</div></div>
      <div><div class="pslbl">Margin</div><div class="psval" style="color:var(--brand)">${margin}%</div></div>
    </div>
    <div class="fc" style="border-color:#fde68a;background:#fffbeb;margin-bottom:11px">
      <div class="fct" style="color:#92400e">Archive Project</div>
      <p style="font-size:var(--sm);color:#78350f;margin-bottom:11px">Archived projects hide from main list but appear under the <strong>Archived</strong> filter.</p>
      <button class="btn btn-amber" onclick="archiveProject()">${p.archived?'♻️ Unarchive':'📁 Archive Project'}</button>
    </div>
    <div class="fc" style="border-color:#fecaca;background:var(--dl)">
      <div class="fct" style="color:#dc2626">Danger Zone</div>
      <p style="font-size:var(--sm);color:#991b1b;margin-bottom:11px">Permanently delete this project. All data will be lost. This cannot be undone.</p>
      <button class="btn btn-danger" onclick="deleteProject()">🗑 Delete Project Permanently</button>
