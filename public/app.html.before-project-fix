async function archiveProject(){
  const p=AP;if(!p)return;
  p.archived=!p.archived;
  p.stage=p.archived?'14 Archived':(p.stage==='14 Archived'?'13 Delivered':p.stage);
  p.timeline.unshift({time:nowStr(),user:currentUser.displayName,action:p.archived?'Project archived':'Project unarchived',old:'',nv:'',type:'admin'});
  await savePatch({archived:p.archived?1:0,stage:p.stage});
  toast(p.archived?'Project archived':'Project unarchived');
  rAdmin(document.getElementById('tb'));
}
async function deleteProject(){
  const p=AP;if(!p)return;
  if(!confirm(`Delete ${p.jobNo} — ${p.vehicle} (${p.owner})?\n\nThis cannot be undone.`))return;
  await DELETE(`/api/projects/${p.id}`);
  projects=projects.filter(x=>x.id!==p.id);
  AP=null;goHome();toast('Project deleted');
}

