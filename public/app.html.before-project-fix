const commas=n=>Math.round(n||0).toLocaleString('en-US');
const fmt=n=>'NT$'+commas(n);
const parseMoney=v=>Number(String(v??'').replace(/[^\d.-]/g,''))||0;
const sObj=l=>STAGES.find(s=>s.l===l)||STAGES[0];
const sIdx=l=>STAGES.findIndex(s=>s.l===l);
const sPct=l=>sObj(l).pct;
const sCol=l=>sObj(l).c;
const itemById=id=>{for(const c of CATALOG)for(const i of c.items)if(i.id===id)return i;return null};
const catOf=id=>{for(const c of CATALOG)if(c.items.find(i=>i.id===id))return c.cat;return 'Other'};
const effP=id=>itemById(id)?.price||0;
const qty=(p,id)=>p.itemQtys[id]||1;
const partCost=item=>(item?.parts||[]).reduce((s,sp)=>s+(parseFloat(sp.cost)||0),0);
const spTot=id=>partCost(itemById(id));
const depPaid=p=>sIdx(p.stage)>=4;
const nowStr=()=>new Date().toISOString().slice(0,16).replace('T',' ');
const calcTotal=p=>{
  const c=p.checkedItems.reduce((s,id)=>s+effP(id)*qty(p,id),0);
  const x=(p.customItems||[]).reduce((s,e)=>s+(parseFloat(e.price)||0)*(e.qty||1),0);
  return c+x;
};
function pstCls(s){return{'Need to Order':'pst-need','Ordered':'pst-ordered','Arrived':'pst-arrived','Installed':'pst-installed','Backordered':'pst-back'}[s]||'pst-none';}
let _tt=null;
function toast(msg,dur=2400){
  const el=document.getElementById('toast');
  el.textContent=msg;el.classList.add('show');
  clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove('show'),dur);
}
function uid(){return 'id-'+Math.random().toString(36).slice(2);}
const quoteUndoStacks=new Map();
const quoteSnapshot=p=>JSON.parse(JSON.stringify({
  checkedItems:p?.checkedItems||[],
  itemQtys:p?.itemQtys||{},
  customItems:p?.customItems||[]
}));
const quoteUndoKey=()=>AP?String(AP.id):'';
function quoteUndoCount(){
  return AP?(quoteUndoStacks.get(quoteUndoKey())||[]).length:0;
}
function pushQuoteUndo(){
  if(!AP)return;
  const key=quoteUndoKey(),stack=quoteUndoStacks.get(key)||[],snap=quoteSnapshot(AP);
  const prev=stack[stack.length-1];
  if(prev&&JSON.stringify(prev)===JSON.stringify(snap))return;
  stack.push(snap);
  if(stack.length>25)stack.shift();
  quoteUndoStacks.set(key,stack);
}
function applyQuoteSnapshot(snap){
  if(!AP||!snap)return;
  AP.checkedItems=[...(snap.checkedItems||[])];
  AP.itemQtys={...(snap.itemQtys||{})};
  AP.customItems=(snap.customItems||[]).map(item=>({...item}));
  AP.saved=false;
}
function refreshQuoteSurfaces(){
  if(activeTab==='consult'){
    buildChecklist();buildQPanel();
  }else if(activeTab==='quote'){
    rQuote(document.getElementById('tb'));
    buildQPanel();
  }else{
    renderTab(activeTab);
  }
  updMobBar();renderDash();
}
function undoQuoteChange(){
  const key=quoteUndoKey(),stack=quoteUndoStacks.get(key)||[],snap=stack.pop();
  if(!snap){toast('Nothing to undo');return;}
  quoteUndoStacks.set(key,stack);
  applyQuoteSnapshot(snap);
  refreshQuoteSurfaces();
  toast('Quote change undone');
}

