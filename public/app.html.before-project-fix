function rmChecked(id){
  pushQuoteUndo();
  const idx=AP.checkedItems.indexOf(id);
  if(idx>=0){AP.checkedItems.splice(idx,1);delete AP.itemQtys[id];}
  AP.timeline.unshift({time:nowStr(),user:currentUser.displayName,action:'Quote item removed',old:itemById(id)?.name||id,nv:'',type:'quote'});
}
function chgCustomQuoteQty(i,delta){
  if(!AP?.customItems?.[i])return;
  pushQuoteUndo();
  const cur=AP.customItems[i].qty||1,nxt=cur+delta;
  if(nxt<1)AP.customItems.splice(i,1);
  else AP.customItems[i].qty=nxt;
  AP.saved=false;
  buildQPanel();updMobBar();rQuote(document.getElementById('tb'));
}
function rmCustomQuoteItem(i){
  if(!AP?.customItems?.[i])return;
  pushQuoteUndo();
  AP.customItems.splice(i,1);
  AP.saved=false;
  buildQPanel();updMobBar();rQuote(document.getElementById('tb'));
}
function openAddQ(){
  // populate cat dropdown from live catalog
  const sel=document.getElementById('aq-cat');
  sel.innerHTML=CATALOG.map(c=>`<option>${c.cat}</option>`).join('');
  document.getElementById('modal-addq').classList.add('open');
}
function addCustomItem(){
  const p=AP;if(!p)return;
  const name=document.getElementById('aq-name').value.trim();
  const price=parseFloat(document.getElementById('aq-price').value)||0;
  const cost=parseFloat(document.getElementById('aq-cost').value)||0;
  const cat=document.getElementById('aq-cat').value;
  if(!name){toast('Enter an item name');return;}
  pushQuoteUndo();
  if(!p.customItems)p.customItems=[];
  p.customItems.push({name,price,cost,qty:1,cat});
  p.timeline.unshift({time:nowStr(),user:currentUser.displayName,action:'Custom item added',old:'',nv:name+' — '+fmt(price),type:'quote'});
  closeModal('modal-addq');
  ['aq-name','aq-price','aq-cost'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  rQuote(document.getElementById('tb'));
}

