// ── PACKAGES ──
function renderPackages(){
  const el=document.getElementById('pkg-list');if(!el)return;
  // Refresh package dropdown in new project modal
  const sel=document.getElementById('m-pkg');
  if(sel){
    sel.innerHTML='<option value="">— No package —</option>'+PACKAGES.map(pk=>`<option value="${pk.id}">${pk.name}</option>`).join('');
  }
  el.innerHTML=PACKAGES.map((pk,pi)=>`
    <div class="pkgrow">
      <div style="flex:1">
        <input class="iedit" value="${pk.name}" onchange="PACKAGES[${pi}].name=this.value;renderPackages()" style="font-size:var(--sm);font-weight:600;width:100%">
        <div style="font-size:var(--xxs);color:var(--g400);margin-top:3px">${pk.items.length} items pre-selected</div>
        <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:5px">
          ${pk.items.map(id=>{const item=itemById(id);return item?`<span style="font-size:11px;background:var(--brand-l);color:var(--brand-d);padding:1px 7px;border-radius:99px">${item.name}</span>`:''}).join('')}
        </div>
        <button class="btn btn-out btn-xs" style="margin-top:7px" onclick="editPkgItems(${pi})">✏️ Edit items</button>
      </div>
      <button class="btn btn-danger btn-xs" onclick="delPackage(${pi})">Delete</button>
    </div>`).join('');
}
function addPackage(){
  PACKAGES.push({id:uid(),name:'New Package',items:[]});
  renderPackages();
  toast('Package added — click to rename and edit items');
}
function delPackage(pi){
  if(!confirm('Delete this package?'))return;
  PACKAGES.splice(pi,1);renderPackages();toast('Package deleted');
}
function editPkgItems(pi){
  const pk=PACKAGES[pi];
  const allItems=CATALOG.flatMap(c=>c.items);
  const checked=new Set(pk.items);
  const html=CATALOG.map(cat=>`
    <div style="margin-bottom:12px">
      <div style="font-size:var(--xxs);font-weight:700;text-transform:uppercase;color:var(--g400);margin-bottom:6px">${cat.icon} ${cat.cat}</div>
      ${cat.items.map(item=>`
        <label style="display:flex;align-items:center;gap:8px;padding:5px 0;cursor:pointer;font-size:var(--sm)">
          <input type="checkbox" ${checked.has(item.id)?'checked':''} onchange="togglePkgItem(${pi},'${item.id}',this.checked)" style="width:16px;height:16px;accent-color:var(--brand)">
          ${item.name} <span style="color:var(--g400);font-size:var(--xxs)">${fmt(item.price)}</span>
        </label>`).join('')}
    </div>`).join('');
  // Show in a simple floating panel
  const panel=document.createElement('div');
  panel.className='pkg-editor-modal';
  panel.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;display:flex;align-items:center;justify-content:center';
  panel.innerHTML=`<div style="background:var(--w);border-radius:var(--r);padding:20px;width:min(520px,95vw);max-height:85dvh;overflow-y:auto;box-shadow:var(--shm)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <div class="bb" style="font-size:20px">Edit: ${pk.name}</div>
      <button type="button" class="btn btn-out btn-sm" data-pkg-done>Done ✓</button>
    </div>
    ${html}
  </div>`;
  panel.querySelector('[data-pkg-done]').addEventListener('click',()=>{
    panel.remove();
    renderPackages();
  });
  document.body.appendChild(panel);
}
function closePkgEditor(){
  document.querySelectorAll('.pkg-editor-modal').forEach(el=>el.remove());
}
function togglePkgItem(pi,itemId,checked){
  const pk=PACKAGES[pi];
  if(checked&&!pk.items.includes(itemId))pk.items.push(itemId);
  else if(!checked)pk.items=pk.items.filter(id=>id!==itemId);
}
function onPkgChange(pkgId){
  // Called when user selects a package in New Project modal
  window._selectedPkgItems=pkgId?PACKAGES.find(p=>p.id===pkgId)?.items||[]:[];
}

// ── CATALOG ──
function renderCatalog(){
  const el=document.getElementById('catalog-settings');if(!el)return;
  el.innerHTML=CATALOG.map((cat,ci)=>`
    <div style="margin-bottom:18px">
      <div class="catrow" style="display:flex;align-items:center;gap:8px;padding:8px 16px;margin:0 -16px;background:var(--g50);border-bottom:1px solid var(--g100)">
        <input class="iedit" value="${cat.icon}" style="width:30px;font-size:18px;text-align:center" onchange="CATALOG[${ci}].icon=this.value">
        <input class="iedit" value="${cat.cat}" style="flex:1;font-size:var(--sm);font-weight:700" onchange="CATALOG[${ci}].cat=this.value">
        <button class="btn btn-danger btn-xs" onclick="delCat(${ci})">Delete Cat</button>
      </div>
      ${cat.items.map((item,ii)=>{
        const spt=partCost(item);
        const retail=item.price||0;
        return`<div class="cprow">
          <div class="cphd">
            <div style="flex:1">
              <input class="iedit" value="${item.name}" style="width:100%;font-size:var(--sm);font-weight:700" onchange="CATALOG[${ci}].items[${ii}].name=this.value">
              <input class="iedit" value="${item.desc}" style="width:100%;font-size:var(--xxs);color:var(--g500);margin-top:3px" onchange="CATALOG[${ci}].items[${ii}].desc=this.value">
            </div>
            <button class="btn btn-danger btn-xs" onclick="delItem(${ci},${ii})">Delete</button>
          </div>
          <div class="pgrid">
            <div class="pbox">
              <div class="plbl">Retail Price</div>
              <input class="pinp" type="text" inputmode="numeric" value="${commas(retail)}" onfocus="this.value=parseMoney(this.value)||''" onchange="CATALOG[${ci}].items[${ii}].price=parseMoney(this.value);renderCatalog()">
            </div>
            <div class="pbox">
              <div class="plbl">Internal Cost</div>
              <div class="cost-display cost-${item.id}">${commas(spt)}</div>
            </div>
            <div class="pbox">
              <div class="plbl">Margin</div>
              <div class="cost-display margin-${item.id}" style="color:${retail>spt?'#15803d':'#dc2626'}">${retail?Math.round((retail-spt)/retail*100)+'%':'—'}</div>
            </div>
          </div>
          <div class="sptog" onclick="toggleSP('spw-${item.id}')">⚙ Sub-parts (${(item.parts||[]).length}) · click to edit</div>
          <div class="spwrap" id="spw-${item.id}">
            <div style="font-size:var(--xxs);font-weight:700;text-transform:uppercase;color:var(--g400);margin-bottom:9px">Parts ordered when this item is selected:</div>
            ${(item.parts||[]).map((sp,si)=>`
              <div class="sprow">
                <input class="spni" value="${sp.name}" placeholder="Part name" onchange="CATALOG[${ci}].items[${ii}].parts[${si}].name=this.value;refreshSPTot(${ci},${ii})">
                <input class="spci" type="text" inputmode="numeric" value="${commas(sp.cost)}" placeholder="0" onfocus="this.value=parseMoney(this.value)||''" onchange="CATALOG[${ci}].items[${ii}].parts[${si}].cost=parseMoney(this.value);this.value=commas(CATALOG[${ci}].items[${ii}].parts[${si}].cost);refreshSPTot(${ci},${ii})">
                <button class="spdel" onclick="delSP(${ci},${ii},${si})">×</button>
              </div>`).join('')}
            <div style="display:flex;gap:7px;margin-top:9px">
              <input class="spni" id="spn-${item.id}" placeholder="New part name" style="flex:1">
              <input class="spci" id="spc-${item.id}" type="text" inputmode="numeric" placeholder="Cost">
              <button class="btn btn-brand btn-sm" onclick="addSP(${ci},${ii},'${item.id}')">+ Add</button>
            </div>
            <div class="sptot"><span class="sptl">Internal cost from sub-parts</span><span class="sptv spt-${item.id}">${fmt(spt)}</span></div>
          </div>
        </div>`;
      }).join('')}
      <button class="btn btn-out btn-xs" style="margin-top:8px" onclick="addItem(${ci})">+ Add Item</button>
    </div>`).join('');
}
function delCat(ci){
  if(!confirm(`Delete category "${CATALOG[ci].cat}" and all its items?`))return;
  CATALOG.splice(ci,1);renderCatalog();toast('Category deleted');
}
function delItem(ci,ii){
  if(!confirm(`Delete "${CATALOG[ci].items[ii].name}"?`))return;
  CATALOG[ci].items.splice(ii,1);renderCatalog();toast('Item deleted');
}
function addItem(ci){
  CATALOG[ci].items.push({id:uid(),name:'New Item',desc:'',price:0,intCost:0,parts:[]});
  renderCatalog();toast('Item added — click name to rename');
}
function addCatalogCategory(){
  CATALOG.push({id:uid(),cat:'New Category',icon:'📦',items:[]});
  renderCatalog();toast('Category added — click name to rename');
}
function refreshSPTot(ci,ii){
  const item=CATALOG[ci]?.items[ii];if(!item)return;
  const t=partCost(item);
  const retail=item.price||0;
  const margin=retail?Math.round((retail-t)/retail*100)+'%':'—';
  document.querySelectorAll('.spt-'+item.id).forEach(el=>el.textContent=fmt(t));
  document.querySelectorAll('.cost-'+item.id).forEach(el=>el.textContent=commas(t));
  document.querySelectorAll('.margin-'+item.id).forEach(el=>{
    el.textContent=margin;
    el.style.color=retail>t?'#15803d':'#dc2626';
  });
}
function addSP(ci,ii,itemId){
  const ne=document.getElementById('spn-'+itemId),ce=document.getElementById('spc-'+itemId);
  if(!ne||!ce)return;
  const name=ne.value.trim(),cost=parseMoney(ce.value);
  if(!name){toast('Enter a part name');return;}
  if(!CATALOG[ci].items[ii].parts)CATALOG[ci].items[ii].parts=[];
  CATALOG[ci].items[ii].parts.push({name,cost});
  toast('Sub-part added ✓');renderCatalog();
  const el=document.getElementById('spw-'+itemId);if(el)el.style.display='block';
}
function delSP(ci,ii,si){
  CATALOG[ci].items[ii].parts.splice(si,1);renderCatalog();
  const itemId=CATALOG[ci]?.items[ii]?.id;
  if(itemId){const el=document.getElementById('spw-'+itemId);if(el)el.style.display='block';}
}
function toggleSP(id){const el=document.getElementById(id);if(el)el.style.display=el.style.display==='none'?'block':'none';}

