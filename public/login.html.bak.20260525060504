<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CRDN Login</title>
  <style>
    body{font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#171410;color:#f6f1e8;min-height:100vh;display:grid;place-items:center;margin:0}
    .card{width:min(440px,calc(100vw - 32px));background:#211d18;border:1px solid #3d3428;border-radius:24px;padding:34px;box-shadow:0 24px 90px rgba(0,0,0,.35)}
    .eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:#d4a96a;margin-bottom:12px}.title{font-size:28px;font-weight:700;margin-bottom:10px}.sub{color:#c9c0b2;line-height:1.55;margin-bottom:26px}.btn{display:block;text-align:center;background:#06c755;color:white;text-decoration:none;font-weight:700;border-radius:14px;padding:14px 18px}.note{font-size:12px;color:#9e9587;margin-top:18px;line-height:1.5}
  </style>
</head>
<body>
  <main class="card">
    <div class="eyebrow">Creative Den</div>
    <div class="title">CRDN Tracking System</div>
    <p class="sub">Sign in with LINE to access the internal vehicle/project tracking dashboard.</p>
    <a class="btn" href="/auth/line">Continue with LINE</a>
    <p class="note">Access is restricted to LINE user IDs listed in the server environment variable <code>ALLOWED_LINE_IDS</code>.</p>
  </main>
</body>
</html>
