  res.json(db.prepare('SELECT * FROM vehicle_timeline WHERE id=?').get(timelineId));
});

app.delete('/api/vehicles/:id/timeline/:timelineId', requireAuth, (req, res) => {
  const vehicleId = Number(req.params.id);
  const timelineId = Number(req.params.timelineId);
  db.prepare('DELETE FROM vehicle_timeline WHERE id=? AND vehicle_id=?').run(timelineId, vehicleId);
  res.json({ ok: true });
});

app.get('/api/admin/users', requireAdmin, (req, res) => {
  res.json(db.prepare(`
    SELECT id, line_user_id, display_name, role, last_login_at, created_at
    FROM users
    ORDER BY CASE role WHEN 'pending' THEN 0 WHEN 'admin' THEN 1 ELSE 2 END, created_at DESC
  `).all());
});

app.post('/api/admin/users', requireAdmin, (req, res) => {
  const lineUserId = nullableText(req.body.line_user_id);
  if (!lineUserId) return res.status(400).json({ error: 'line_user_id is required' });
  const role = ['admin', 'pending', 'disabled'].includes(req.body.role) ? req.body.role : 'admin';
  db.prepare(`
    INSERT INTO users (line_user_id, display_name, role)
    VALUES (?, ?, ?)
    ON CONFLICT(line_user_id) DO UPDATE SET display_name=excluded.display_name, role=excluded.role
  `).run(lineUserId, nullableText(req.body.display_name), role);
  res.status(201).json(getUser(lineUserId));
});

app.patch('/api/admin/users/:userId', requireAdmin, (req, res) => {
  const id = Number(req.params.userId);
  const current = db.prepare('SELECT * FROM users WHERE id=?').get(id);
  if (!current) return res.status(404).json({ error: 'User not found' });
  const role = ['admin', 'pending', 'disabled'].includes(req.body.role) ? req.body.role : current.role;
  if (current.line_user_id === req.session.user.userId && role !== 'admin') {
    return res.status(400).json({ error: 'You cannot remove your own admin access' });
  }
  db.prepare('UPDATE users SET display_name=?, role=? WHERE id=?')
    .run(nullableText(req.body.display_name ?? current.display_name), role, id);
  res.json(db.prepare('SELECT id, line_user_id, display_name, role, last_login_at, created_at FROM users WHERE id=?').get(id));
});

app.get('/api/vehicles/:id/history', requireAuth, (req, res) => {
  const vehicleId = Number(req.params.id);
  res.json(db.prepare('SELECT * FROM vehicle_history WHERE vehicle_id=? ORDER BY created_at DESC, id DESC LIMIT 100').all(vehicleId));
});

