app.post('/api/vehicles', requireAuth, (req, res) => {
  const { owner, name } = req.body;
  if (!owner || !name) return res.status(400).json({ error: 'owner and name are required' });
  const result = db.prepare(`
    INSERT INTO vehicles (
      job_no, owner, name, plate, pkg, stage, designer, priority, progress,
      start_date, finish_date, customer_update, customer_action, notes, created_by
    )
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
  `).run(
    nullableText(req.body.job_no) || nextJobNo(),
    owner,
    name,
    nullableText(req.body.plate),
    nullableText(req.body.pkg),
    nullableText(req.body.stage) || '01 Intake',
    nullableText(req.body.designer),
    nullableText(req.body.priority) || 'Normal',
    Math.max(0, Math.min(100, intOrZero(req.body.progress))),
    nullableText(req.body.start_date),
    nullableText(req.body.finish_date),
    nullableText(req.body.customer_update),
    nullableText(req.body.customer_action),
    nullableText(req.body.notes),
    req.session.user.userId
  );
  ensureVehicleTimeline(result.lastInsertRowid);
  logVehicleHistory(result.lastInsertRowid, req.session.user.userId, 'created', req.body);
  res.status(201).json(db.prepare('SELECT * FROM vehicles WHERE id=?').get(result.lastInsertRowid));
});

