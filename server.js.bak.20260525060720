    UPDATE vehicles
    SET job_no=?, owner=?, name=?, plate=?, pkg=?, stage=?, designer=?, priority=?, progress=?,
        start_date=?, finish_date=?, customer_update=?, customer_action=?, notes=?, updated_at=CURRENT_TIMESTAMP
    WHERE id=?
  `).run(
    nullableText(next.job_no),
    next.owner,
    next.name,
    nullableText(next.plate),
    nullableText(next.pkg),
    nullableText(next.stage) || '01 Intake',
    nullableText(next.designer),
    nullableText(next.priority) || 'Normal',
    Math.max(0, Math.min(100, intOrZero(next.progress))),
    nullableText(next.start_date),
