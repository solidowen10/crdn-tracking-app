app.get('/api/vehicles/:id/checklist', requireAuth, (req, res) => {
  const vehicleId = Number(req.params.id);
  const vehicle = getVehicle(vehicleId);
  if (!vehicle) return res.status(404).json({ error: 'Vehicle not found' });
  const categories = db.prepare('SELECT * FROM catalog_categories ORDER BY sort_order, id').all();
  const rows = db.prepare(`
    SELECT i.id, i.category_id, i.name, i.description, i.default_price, i.sort_order,
           COALESCE(vc.checked, 0) AS checked
    FROM catalog_items i
    LEFT JOIN vehicle_checklist vc ON vc.item_id=i.id AND vc.vehicle_id=?
    WHERE i.active=1
    ORDER BY i.sort_order, i.id
  `).all(vehicleId);
  res.json(categories.map(c => ({ ...c, items: rows.filter(i => i.category_id === c.id) })));
});

app.patch('/api/vehicles/:id/checklist', requireAuth, (req, res) => {
  const vehicleId = Number(req.params.id);
  if (!getVehicle(vehicleId)) return res.status(404).json({ error: 'Vehicle not found' });
  const updates = Array.isArray(req.body) ? req.body : [];
  const stmt = db.prepare(`
    INSERT INTO vehicle_checklist (vehicle_id, item_id, checked, custom_price, updated_at)
    VALUES (?, ?, ?, NULL, CURRENT_TIMESTAMP)
    ON CONFLICT(vehicle_id, item_id) DO UPDATE SET checked=excluded.checked, custom_price=NULL, updated_at=CURRENT_TIMESTAMP
  `);
  const tx = db.transaction(() => {
    updates.forEach(u => stmt.run(vehicleId, Number(u.itemId), u.checked ? 1 : 0));
  });
  tx();
  logVehicleHistory(vehicleId, req.session.user.userId, 'checklist_updated', { count: updates.length });
  res.json({ ok: true });
});

